        "description_style": "body",
        "collection": "all",
        "products_to_show": 8,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "full_width": false,
        "show_view_all": true,
        "view_all_style": "solid",
        "enable_desktop_slider": false,
        "swipe_on_mobile": true,
        "image_ratio": "portrait",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "quick_add": "standard",
        "columns_mobile": "2",
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "features": {
      "type": "multicolumn",
      "blocks": {
        "col1": {
          "type": "column",
          "settings": {
            "title": "Free Shipping",
            "text": "<p>On all orders over $75. No code needed at checkout.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "col2": {
          "type": "column",
          "settings": {
            "title": "Easy Returns",
            "text": "<p>30-day hassle-free returns on everything we sell.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "col3": {
          "type": "column",
          "settings": {
            "title": "Secure Checkout",
            "text": "<p>Your payment info is always protected and encrypted.<\/p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": ["col1", "col2", "col3"],
      "settings": {
        "title": "",
        "heading_size": "h2",
        "image_width": "full",
        "image_ratio": "adapt",
        "columns_desktop": 3,
        "column_alignment": "center",
        "background_style": "none",
        "button_label": "",
        "button_link": "",
        "color_scheme": "scheme-2",
        "columns_mobile": "1",
        "swipe_on_mobile": false,
        "padding_top": 60,
        "padding_bottom": 60
