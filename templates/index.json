{
  "sections": {
    "hero": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Welcome to {{ shop.name }}",
            "heading_size": "h0"
          }
        },
        "caption": {
          "type": "caption",
          "settings": {
            "caption": "New arrivals now available",
            "text_style": "subtitle",
            "text_size": "large"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Discover our curated collection \u2014 crafted with quality and made to last.<\/p>",
            "text_style": "body"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Shop All",
            "button_link": "shopify:\/\/collections\/all",
            "button_style_secondary": false,
            "button_label_2": "",
            "button_link_2": "",
            "button_style_secondary_2": true
          }
        }
      },
      "block_order": ["heading", "caption", "text", "button"],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "center",
        "color_scheme": "scheme-4",
        "full_width": true,
        "padding_top": 100,
        "padding_bottom": 100
      }
    },
    "featured_collection": {
      "type": "featured-collection",
      "settings": {
        "title": "Shop Now",
        "heading_size": "h2",
        "description": "",
